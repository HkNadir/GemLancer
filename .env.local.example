# ═══════════════════════════════════════════════════════
# GemLancer — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.
# ═══════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Stripe ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Stripe Price IDs (create these in Stripe Dashboard)
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly_id
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_id
STRIPE_PRICE_AGENCY_MONTHLY=price_agency_monthly_id

# ── Email (Resend) ───────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@gemlancer.com
RESEND_FROM_NAME=GemLancer

# ── App ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Optional: Analytics ──────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
